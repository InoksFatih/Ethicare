# Copy to backend/.env and fill in. Never commit .env.

# OpenAI — used for Live Mode scenario generation AND classroom/join free-text evaluation (Dr. Ethics, clustering).
# Without this, evaluation falls back to Anthropic (if set) then offline heuristics.
OPENAI_API_KEY=
# Optional: model id (default gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini
# Optional: API base (Azure / proxy)
# OPENAI_API_BASE=https://api.openai.com/v1

# Anthropic — optional fallback for classroom/join evaluation if OpenAI is unset; also used for in-game Dr. Ethics on /cases decision path if configured in engine.
# ANTHROPIC_API_KEY=
