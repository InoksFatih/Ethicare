# Copy to .env.local (never commit .env.local).

# Public FastAPI base (must be reachable from the internet for mobile / other networks)
NEXT_PUBLIC_API_URL=https://your-api.example.com

# WebSocket base (production: wss:// — same host as API in most setups)
NEXT_PUBLIC_WS_URL=wss://your-api.example.com

# Optional: force QR / join link host (defaults to current browser origin)
NEXT_PUBLIC_PUBLIC_JOIN_BASE_URL=https://your-app.example.com
